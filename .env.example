# Database
DATABASE_URL="postgresql://user:password@localhost:5432/tracktheirprofile"

# Authentication (REQUIRED in production)
JWT_SECRET="your-random-secret-here-min-32-chars"

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Google Custom Search (for deep Reddit search)
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ID=

# Admin Dashboard (REQUIRED in production)
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Cloudflare Turnstile (bot protection on login/signup)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Email Notifications (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@tracktheirprofile.com
ADMIN_NOTIFICATION_EMAIL=

# Application
APP_URL=http://localhost:3000
NODE_ENV=development
